# Copy this file to .env and fill in real values. .env is gitignored - never commit it.
# These variable names are the single source of truth used consistently across
# packages/scraper-core, scraper/, worker/ (as wrangler secrets) and infra/*.sh.

# --- Turso / libSQL (per-project database) ---
# Created by infra/provision.sh (or manually via `turso db create <name>`).
# Leave both empty to run the scraper in local-only demo mode (no cloud account needed).
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# --- Local SQLite ---
# Path to the local SQLite file used for dedup bookkeeping + the delta-sync outbox.
LOCAL_SQLITE_PATH=./data/local.db

# --- Healthchecks.io (optional) ---
# Leave empty to skip health pings entirely (no-op). If the org-level
# HEALTHCHECKS_API_KEY secret is set, infra/provision.sh creates this
# automatically and writes it as the HEALTHCHECK_URL repo secret - copy it
# from there. Otherwise, get a free ping URL by hand at healthchecks.io.
HEALTHCHECK_URL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Dummy example scraper source ---
SCRAPE_SOURCE_URL=https://jsonplaceholder.typicode.com/posts

# =============================================================================
# The variables below are NOT read by the Python scraper - they belong to the
# Cloudflare Worker (set via `wrangler secret put`, never committed) and to
# infra/*.sh. Listed here for a single source-of-truth overview of every secret
# name used across this template.
# =============================================================================

# --- Cloudflare Worker secrets (see worker/wrangler.toml comments) ---
# SESSION_HMAC_SECRET     - random 32+ byte secret used to sign session cookies
# ADMIN_USER              - v1 "secret-mode" admin username (see infra/add-user.sh)
# ADMIN_PW_HASH           - v1 "secret-mode" admin password hash
# TURSO_DATABASE_URL      - same DB as above, used by the Worker's libsql client
# TURSO_AUTH_TOKEN        - same DB as above, used by the Worker's libsql client

# --- Cloudflare Worker [vars] - committed, NOT secret, see wrangler.toml ---
# ALLOWED_ORIGIN           - the GitHub Pages origin allowed by CORS, e.g. https://<user>.github.io
#                            filled in automatically by infra/provision.sh

# --- GitHub Actions / infra secrets (org-level, set once, not per-repo) ---
# CLOUDFLARE_API_TOKEN     - used by bootstrap.yml/deploy.yml + infra/provision.sh
# TURSO_PLATFORM_TOKEN     - used by infra/provision.sh to create/destroy Turso databases
# TURSO_ORG                - your Turso organization slug
# HEALTHCHECKS_API_KEY     - OPTIONAL. Healthchecks.io Management API key (Project
#                            Settings -> API access). If set, infra/provision.sh
#                            auto-creates a per-project healthcheck. If unset, that
#                            step is skipped entirely - no error, no HEALTHCHECK_URL
#                            secret is written, and you can still set HEALTHCHECK_URL
#                            by hand above.

# --- Repo-level secrets written back by infra/provision.sh via `gh secret set` ---
# CLOUDFLARE_ACCOUNT_ID
# CF_WORKER_NAME
# TURSO_DB_NAME
# HEALTHCHECK_URL          - only written if the HEALTHCHECKS_API_KEY org-secret is set
